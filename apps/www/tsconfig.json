{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/components/*": ["../packages/ui/src/components/*"],
      "@workspace/ui/lib/*": ["../packages/ui/src/lib/*"],
      "@workspace/ui/ui/*": ["../packages/ui/src/ui/*"],
      "@workspace/ui/styles/*": ["../packages/ui/src/styles/*"]
    },
    "moduleResolution": "Bundler"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts"
, "../../drizzle.config.ts"  ],
  "exclude": ["node_modules"]
}
